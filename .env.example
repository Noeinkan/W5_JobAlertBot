# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_GUILD_ID=optional_guild_id_for_instant_command_updates
DISCORD_WEBHOOK_URL=

# Adzuna: https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# Reed: https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=your_api_key

# Serper.dev: https://serper.dev/
SERPER_API_KEY=your_api_key

# Optional tuning
SERPER_CACHE_MINUTES=360
API_DELAY_MS=1000
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY_MS=1500
LOG_LEVEL=info
STARTUP_RUN_ON_BOOT=false
RUN_ONCE=false

